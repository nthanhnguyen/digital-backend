# Environment
NODE_ENV=local
NODE_PORT=9000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=digital_wallet_service

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=10
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=10
PASSWORD_MIN_LENGTH=8

# Airwallex
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=your_airwallex_client_id
AIRWALLEX_API_KEY=your_airwallex_api_key
AIRWALLEX_ENV=demo
# x-api-version header for all Airwallex API calls (optional; defaults to 2023-05-16)
AIRWALLEX_API_VERSION=2023-05-16
# Webhook secret from Airwallex web app (Settings > Developer > Webhooks, per notification URL)
AIRWALLEX_WEBHOOK_SECRET=your_webhook_secret

# File Storage (S3-compatible)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=digital-wallet-mvp-documents
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_id